# ==================================================
# MangoWM Keybindings Configuration (keybindings.conf)
# ==================================================

# Core Application Bindings
keyrule=mods:Mod4,key:Return,action:exec kitty
keyrule=mods:Mod4,key:space,action:exec rofi -show drun
keyrule=mods:Mod4,key:Q,action:close
keyrule=mods:Mod4,key:E,action:exec thunar
keyrule=mods:Mod4,key:B,action:exec xdg-open https://

# Utilities & Window States
keyrule=mods:Mod4,key:W,action:exec wall-random
keyrule=mods:Mod4,key:Shift,key:W,action:exec waybar-reload
keyrule=mods:Mod4,key:F,action:fullscreen
keyrule=mods:Mod4,key:Shift,key:P,action:exec flameshot gui
keyrule=mods:Mod4,key:V,action:toggle_floating

# Session Control
keyrule=mods:Mod4,key:Escape,action:exec hyprlock
keyrule=mods:Mod4,key:Shift,key:Escape,action:exit

# Focus Management (Directional)
keyrule=mods:Mod4,key:left,action:focus:l
keyrule=mods:Mod4,key:right,action:focus:r
keyrule=mods:Mod4,key:up,action:focus:u
keyrule=mods:Mod4,key:down,action:focus:d

# Window Layout Swapping
keyrule=mods:Mod4,key:Shift,key:left,action:swap:l
keyrule=mods:Mod4,key:Shift,key:right,action:swap:r
keyrule=mods:Mod4,key:Shift,key:up,action:swap:u
keyrule=mods:Mod4,key:Shift,key:down,action:swap:d

# Window Resizing Actions
keyrule=mods:Mod4,key:minus,action:resize:width:-100
keyrule=mods:Mod4,key:equal,action:resize:width:100
keyrule=mods:Mod4,key:Shift,key:minus,action:resize:height:-100
keyrule=mods:Mod4,key:Shift,key:equal,action:resize:height:100

# View Tags (Equivalent to Switch Workspaces)
keyrule=mods:Mod4,key:1,action:view_tag:1
keyrule=mods:Mod4,key:2,action:view_tag:2
keyrule=mods:Mod4,key:3,action:view_tag:3
keyrule=mods:Mod4,key:4,action:view_tag:4
keyrule=mods:Mod4,key:5,action:view_tag:5
keyrule=mods:Mod4,key:6,action:view_tag:6
keyrule=mods:Mod4,key:7,action:view_tag:7
keyrule=mods:Mod4,key:8,action:view_tag:8
keyrule=mods:Mod4,key:9,action:view_tag:9
keyrule=mods:Mod4,key:0,action:view_tag:10

# Relative Tag Navigation
keyrule=mods:Mod4,key:comma,action:view_tag:relative:-1
keyrule=mods:Mod4,key:period,action:view_tag:relative:1

# Move Active Windows to Specified Tags
keyrule=mods:Mod4,key:Shift,key:1,action:set_tag:1
keyrule=mods:Mod4,key:Shift,key:2,action:set_tag:2
keyrule=mods:Mod4,key:Shift,key:3,action:set_tag:3
keyrule=mods:Mod4,key:Shift,key:4,action:set_tag:4
keyrule=mods:Mod4,key:Shift,key:5,action:set_tag:5
keyrule=mods:Mod4,key:Shift,key:6,action:set_tag:6
keyrule=mods:Mod4,key:Shift,key:7,action:set_tag:7
keyrule=mods:Mod4,key:Shift,key:8,action:set_tag:8
keyrule=mods:Mod4,key:Shift,key:9,action:set_tag:9
keyrule=mods:Mod4,key:Shift,key:0,action:set_tag:10

# Media Keys & Hardware Drivers (Volume / Brightness Control)
keyrule=key:XF86AudioRaiseVolume,action:exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
keyrule=key:XF86AudioLowerVolume,action:exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
keyrule=key:XF86AudioMute,action:exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
keyrule=key:XF86AudioMicMute,action:exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
keyrule=key:XF86MonBrightnessUp,action:exec brightnessctl s 10%+
keyrule=key:XF86MonBrightnessDown,action:exec brightnessctl s 10%-

# Media Streaming Player Controls
keyrule=key:XF86AudioNext,action:exec playerctl next
keyrule=key:XF86AudioPause,action:exec playerctl play-pause
keyrule=key:XF86AudioPlay,action:exec playerctl play-pause
keyrule=key:XF86AudioPrev,action:exec playerctl previous

# Cursor Manipulations & Floating Controls
mousetoggle=mods:Mod4,button:left,action:move_window
mousetoggle=mods:Mod4,button:right,action:resize_window
