# =====================================================================
# MangoWM Window & Layer Criteria Configurations (layouts.conf)
# =====================================================================

# Zotero Popup Handlers
windowrule=class:^(Zotero)$,title:.*Preferences.*,floating:1
windowrule=class:^(Zotero)$,title:.*Citation.*,floating:1

# XWayland Drag & Drop Drag fixes
windowrule=class:^$,xwayland:1,floating:1,fullscreen:0,nofocus:1

# KCalc Sizing & Engine Fixes
windowrule=class:^(org.kde.kcalc)$,floating:1
windowrule=class:^(org.kde.kcalc)$,width:400,height:400
windowrule=class:^(org.kde.kcalc)$,focus_on_activate:1

# MPV Audio-only Content Masking
windowrule=class:^(mpv)$,content:none

# XWayland Video Bridge Background Cloaking
windowrule=class:^(xwaylandvideobridge)$,opacity:0.0
windowrule=class:^(xwaylandvideobridge)$,animation:0
windowrule=class:^(xwaylandvideobridge)$,no_initial_focus:1
windowrule=class:^(xwaylandvideobridge)$,max_width:1,max_height:1
windowrule=class:^(xwaylandvideobridge)$,blur:0
windowrule=class:^(xwaylandvideobridge)$,nofocus:1

# Flameshot Region Overlay Corrections
windowrule=title:^(flameshot)$,floating:1
windowrule=title:^(flameshot)$,x:0,y:0
windowrule=title:^(flameshot)$,pinned:1
windowrule=title:^(flameshot)$,fullscreen:0

# Menu Core Animations Override
windowrule=class:^(wofi)$,animation:0

# =====================================================================
# Compositor Layer Rules (Waybar, Wofi, Panel Contexts)
# =====================================================================
# Note: MangoWM structures application layer overrides using a unified
# namespace criteria matching layout string directly in its master block.

layerrule=namespace:^(wofi)$,blur:1
layerrule=namespace:^(wofi)$,animation:0
layerrule=namespace:^(wofi)$,ignore_alpha:0.5

layerrule=namespace:^(waybar)$,blur:1
